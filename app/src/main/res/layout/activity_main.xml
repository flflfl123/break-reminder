<?xml version="1.0" encoding="utf-8"?>
<!-- 主界面布局 -->
<!-- 简约清新风格，参考Stretchly的托盘图标功能 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- ======== 顶部Logo和标题区域 ======== -->
        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginTop="32dp" />

        <TextView
            android:id="@+id/tvAppSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_subtitle"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="8dp" />

        <!-- ======== 状态显示区域 ======== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_background"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <!-- 服务状态指示 -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已停止"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/status_stopped" />

                <!-- 下次休息信息 -->
                <TextView
                    android:id="@+id/tvNextBreakInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击\"开始提醒\"启动服务"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="12dp"
                    android:gravity="center" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ======== 操作按钮区域 ======== -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnToggleService"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="开始提醒"
            android:textSize="18sp"
            app:cornerRadius="28dp"
            app:backgroundTint="@color/button_primary"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="设置"
            android:textSize="16sp"
            app:cornerRadius="24dp"
            app:strokeColor="@color/button_primary"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <!-- 自启动权限引导按钮（仅需要的厂商显示） -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAutoStart"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="开启自启动权限"
            android:textSize="14sp"
            android:textColor="@color/text_hint"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
